{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.auvita.tw/schemas/promotions/schedule.schema.json",
  "title": "Promotion Schedule",
  "description": "AeroJet 官網促銷活動總排程。行銷唯一觸碰點。",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "image", "startAt", "endAt", "zh-TW", "en", "ja"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_-]+$",
        "description": "唯一識別碼，建議用 YYYY-MM-promo-N 格式"
      },
      "image": {
        "type": "string",
        "pattern": "^(/images/promotions/.+\\.(jpg|jpeg|png|webp)|https?://.+)$",
        "description": "圖片路徑（相對 /images/promotions/ 或外部 URL）"
      },
      "startAt": {
        "type": "string",
        "format": "date",
        "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
        "description": "促銷開始日期（YYYY-MM-DD，當日 00:00 起 active）"
      },
      "endAt": {
        "type": "string",
        "format": "date",
        "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
        "description": "促銷結束日期（YYYY-MM-DD，當日 23:59 仍 active，隔日移入 archive）"
      },
      "archivedAt": {
        "type": "string",
        "format": "date-time",
        "description": "自動歸檔時間戳（由 build-active.mjs 寫入，行銷請勿手填）"
      },
      "zh-TW": { "$ref": "#/$defs/localeContent" },
      "en":    { "$ref": "#/$defs/localeContent" },
      "ja":    { "$ref": "#/$defs/localeContent" }
    }
  },
  "$defs": {
    "localeContent": {
      "type": "object",
      "required": ["title", "description"],
      "additionalProperties": false,
      "properties": {
        "title":       { "type": "string", "minLength": 1, "maxLength": 50 },
        "description": { "type": "string", "minLength": 1, "maxLength": 200 }
      }
    }
  }
}
