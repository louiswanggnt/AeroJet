  "about": {
    "subtitle": "About GNT",
    "title": "關於京華堂",
    "desc": "京華堂 (GNT) 致力於皮膚照料設備、高純度真空汽化貴金屬生醫材料\n以突破性的專利技術引領無創美容的新紀元\n運用20年的實證經驗\n帶來更安全、更有效、更科學的治療體驗。",
    "products": {
      "p1": {
        "title": "藥物/美容液導入儀",
        "desc": "結合流體力學與精密工程，提供無創、無痛的高效活性成分導入解決方案。"
      },
      "p2": {
        "title": "汽化金、汽化銀工藝",
        "desc": "專研汽化金屬材料，應用於食品、生技與藥物發展。"
      },
      "p3": {
        "title": "智慧長照床",
        "desc": "使用汽缸支撐體位全時體位偵測、防治褥創。自動如廁盥洗控制、AI遠端監控。"
      }
    }
  },
  "faq": {
    "subtitle": "常見問題",
    "title": "解答您的疑惑",
    "questions": [
      {
        "q": "AuJet 可以搭配哪些活性成分？",
        "a": "主要使用汽化金、銀，亦可包含小分子玻尿酸、生長因子、外泌體 、及各式液態化妝品。由於是物理性導入，不會破壞成分活性。只要是無沉澱物之溶液皆可作施打"
      },
      {
        "q": "使用 AuJet 療程會有痛感嗎？",
