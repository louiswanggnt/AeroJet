# Next.js static export routing for Apache
# 由 next build 複製 public/.htaccess → out/.htaccess → FTP 上傳到 auvita.tw 根目錄

RewriteEngine On

# 關掉 mod_dir 自動加結尾斜線
# Next.js static export 為 /zh-TW 同時產出 zh-TW.html + zh-TW/ 目錄，
# 若 mod_dir 自動把 /zh-TW 改重導到 /zh-TW/，會跟下面的 trailing-slash 移除
# 規則形成 301 死循環
DirectorySlash Off

# 預設語系：根路徑 / 重導至 /zh-TW
RewriteRule ^$ /zh-TW [R=302,L]

# 移除結尾斜線（無條件，讓 /zh-TW/ → /zh-TW，再由下一條規則處理為 .html）
# 不加 -d 條件，因為 Next.js static export 為每個 route 同時產生 xxx/ 目錄
# 與 xxx.html 檔案，我們要的是 .html 而非進入目錄
RewriteRule ^(.+)/$ /$1 [R=301,L]

# 無副檔名請求 → 嘗試 .html 檔（Next.js static export 產出格式）
# 不檢查 !-d：Next.js 為每個 route 同時產生 zh-TW.html 檔 + zh-TW/ 目錄，
# 我們要 .html 檔，不要進入空目錄
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)$ /$1.html [L]

# 自訂 404
ErrorDocument 404 /404.html

# 安全：禁止列出目錄
Options -Indexes

# 快取靜態資源
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Gzip 壓縮
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/plain
</IfModule>
