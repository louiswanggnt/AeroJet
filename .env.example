# ─────────────────────────────────────────────────────────────
# AeroJet 官網 — 環境變數模板
# 複製此檔為 .env.local 並填入實際值（.env.local 不會進 git）
# ─────────────────────────────────────────────────────────────

# 公開的網站 URL（SEO canonical / sitemap / metadataBase）
# 本機 dev 可填 http://localhost:3000；上線必填正式網域
NEXT_PUBLIC_SITE_URL="https://www.auvita.tw"

# Gemini API Key（AI Studio 開發專用，生產不需要）
# AI Studio 會在 Cloud Run 自動注入；本機開發在 Secrets 面板設定
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AI Studio 注入的 App URL（生產環境不需要）
APP_URL="MY_APP_URL"
